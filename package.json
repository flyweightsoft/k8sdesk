{
  "name": "k8sdesk",
  "version": "0.1.0",
  "description": "Minimal, isolated, safe Kubernetes desktop client (no system kubectl required)",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 1420",
    "build": "ng build",
    "tauri": "tauri",
    "dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "package": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "monaco-editor": "^0.55.1",
    "ngx-monaco-editor-v2": "^18.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "~5.4.0"
  }
}
