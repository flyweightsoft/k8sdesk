{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "k8sdesk",
  "version": "0.1.0",
  "identifier": "dev.k8sdesk.app",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/browser"
  },
  "app": {
    "windows": [
      {
        "title": "k8sdesk",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Safe Kubernetes desktop client",
    "longDescription": "Isolated Kubernetes client that never reads or modifies the system kubeconfig."
  },
  "plugins": {}
}
